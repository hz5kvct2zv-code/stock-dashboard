{
  "manifest_version": 3,
  "name": "Schwab Priority Watch Alerts",
  "version": "0.1.0",
  "description": "Reads Schwab watchlist rows and alerts when priority stocks turn upward after cooling off.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://client.schwab.com/app/trade/watchlist*",
    "https://trade.thinkorswim.com/watchlist*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://client.schwab.com/app/trade/watchlist*",
        "https://trade.thinkorswim.com/watchlist*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
